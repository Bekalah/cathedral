{
  "name": "cathedral-magnum-opus",
  "version": "1.0.0",
  "description": "🜏 Living codex-engine: Codex 144:99 · Fusion Kink (A×B=D) · Liber Arcanae - Complete consolidation of all 13 repos",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "standardize:packages": "bash scripts/standardize-all-packages.sh",
    "standardize:tsconfig": "bash scripts/standardize-tsconfig.sh",
    "secure:all": "bash scripts/secure-all-systems.sh",
    "web:dev": "cd apps/web && pnpm run dev",
    "web:build": "cd apps/web && pnpm run build",
    "console": "pnpm run dev --workspace=packages/web-platform",
    "cathedral": "cd godot && godot --path .",
    "rust:build": "cd rust-engines && cargo build --release",
    "rust:test": "cd rust-engines && cargo test",
    "godot:build": "bash scripts/build-godot.sh",
    "fusion": "echo 'Fusion Kink: A x B = D' && pnpm run rust:build && pnpm run godot:build",
    "cleanup:junk": "bash scripts/cleanup-junk.sh",
    "protect:check": "bash .husky/pre-commit",
    "consolidate": "bash tools/sync/consolidate_repos.sh",
    "sync": "bash tools/sync/cathedral_master_sync.sh",
    "verify:connections": "ts-node scripts/verify-cross-connections.ts",
    "build:connections": "bash scripts/build-cross-connections.sh",
    "security:audit": "ts-node scripts/security-audit.ts",
    "recover:connections": "ts-node scripts/recover-broken-connections.ts",
    "recover:all": "bash scripts/complete-recovery.sh",
    "recover:data": "bash scripts/comprehensive-data-recovery.sh",
    "recover:continuous": "bash scripts/continuous-data-recovery.sh",
    "recover:verify": "bash scripts/verify-recovered-data.sh",
    "integrate:data": "bash scripts/integrate-all-data.sh",
    "improve:connections": "tsx scripts/improve-all-connections.ts",
    "improve:exports": "tsx scripts/improve-package-exports.ts",
    "secure:integrate:improve": "bash scripts/secure-integrate-improve.sh",
    "improve:merge": "bash scripts/improve-and-merge.sh",
    "merge:data": "tsx scripts/merge-duplicate-data.ts",
    "merge:packages": "tsx scripts/consolidate-packages.ts",
    "merge:repos": "bash scripts/merge-from-other-repos.sh",
    "improve:continuous": "bash scripts/continuous-improve.sh",
    "improve:all": "bash scripts/improve-and-merge.sh && bash scripts/secure-integrate-improve.sh",
    "perfect:secure": "bash scripts/perfect-secure-system.sh",
    "fix:json": "bash scripts/fix-all-json.sh",
    "auto:update": "bash scripts/auto-update.sh",
    "fix:imports": "ts-node scripts/fix-broken-imports.ts",
    "fix:console": "bash scripts/remove-console-injection.sh",
    "fix:all": "bash scripts/complete-fix.sh",
    "security:check": "bash scripts/perfect-secure-system.sh",
    "security:auto": "bash scripts/auto-update.sh",
    "clean:all": "find . -name \"*.log\" -o -name \"*.tmp\" -o -name \".DS_Store\" | xargs rm -f",
    "quality:check": "tsx scripts/deep-quality-analysis.ts || true",
    "analyze:real-vs-spam": "bash scripts/analyze-real-vs-spam.sh",
    "remove:spam": "bash scripts/remove-spam-and-fix.sh",
    "remove:npm": "bash scripts/remove-npm-enforce-pnpm.sh",
    "enforce:pnpm": "bash scripts/enforce-pnpm.sh",
    "review:tools": "bash scripts/review-all-tools-versions.sh",
    "standardize:tools": "bash scripts/standardize-all-tool-versions.sh",
    "audit:tools": "tsx scripts/audit-all-tool-versions.ts",
    "rust:dev": "cd rust-engines && cargo watch -x run",
    "rust:check": "cd rust-engines && cargo check",
    "dioxus:dev": "cd rust-engines/dioxus-cathedral && dx serve",
    "dioxus:build": "cd rust-engines/dioxus-cathedral && dx build --release",
    "bevy:build": "cd rust-engines/bevy-cathedral && cargo build --release",
    "bevy:run": "cd rust-engines/bevy-cathedral && cargo run",
    "bevy:wasm": "cd rust-engines/bevy-cathedral && cargo build --release --target wasm32-unknown-unknown",
    "deploy:all": "bash scripts/deploy-all-free.sh",
    "deploy:setup": "bash scripts/setup-free-platforms.sh",
    "deploy:monitor": "bash scripts/monitor-free.sh",
    "deploy:vercel": "vercel --prod",
    "deploy:cloudflare": "wrangler pages deploy apps/web/out --project-name=cathedral",
    "deploy:fly": "flyctl deploy",
    "deploy:github": "git push origin main",
    "validate:integrity": "tsx scripts/validate-integrity.ts",
    "fix:integrity": "bash scripts/fix-all-integrity.sh",
    "check:design": "bash scripts/check-design-quality.sh",
    "protect:all": "pnpm run fix:integrity && pnpm run validate:integrity && pnpm run check:design",
    "consolidate:data": "bash scripts/consolidate-all-data.sh",
    "verify:data": "find data -name '*.json' -exec python3 -c \"import json; json.load(open('{}'))\" \\; -print"
  },
  "keywords": [
    "fusion-kink",
    "codex-14499",
    "liber-arcanae",
    "cathedral",
    "hermetic-engine",
    "sacred-geometry",
    "tarot-system",
    "godot",
    "rust",
    "alchemy",
    "western-mystery-tradition"
  ],
  "author": "Rebecca Respawn <bekalah>",
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bekalah/cathedral.git"
  },
  "homepage": "https://bekalah.github.io/cathedral",
  "dependencies": {
    "@octokit/rest": "^22.0.1"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "5.6.0"
  },
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=8.15.0"
  }
}
