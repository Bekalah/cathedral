{
  "name": "@cathedral/design-library",
  "version": "1.0.0",
  "description": "Figma-style design library integrating Codex 144:99, Liber Arcanae, and Fusion Kink",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "design": "node dist/design/designStudio.js",
    "components": "node dist/components/generateComponents.js",
    "palettes": "node dist/colors/sacredPalettes.js",
    "patterns": "node dist/patterns/sacredPatterns.js",
    "export": "node dist/export/exportDesigns.js"
  },
  "dependencies": {
    "@cathedral/codex-144-99": "workspace:*",
    "@cathedral/liber-arcanae": "workspace:*",
    "@cathedral/plugin-system": "workspace:*",
    "@cathedral/shared": "workspace:*",
    "@cathedral/master-art-principles": "workspace:*",
    "canvas": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "design-library",
    "figma-alternative",
    "sacred-design",
    "codex-144-99",
    "liber-arcanae",
    "fusion-kink",
    "sacred-geometry",
    "design-system"
  ],
  "author": "Rebecca Respawn",
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bekalah/cathedral.git",
    "directory": "packages/cathedral-design-library"
  },
  "homepage": "https://bekalah.github.io/cathedral/packages/cathedral-design-library",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=8.15.0"
  }
}
