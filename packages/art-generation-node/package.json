  "homepage": "https://bekalah.github.io/cathedral/packages/art-generation-node",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=8.15.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
