{
  "name": "@cathedral/art-generation-node",
  "version": "1.0.0",
  "description": "High-end art generation and pattern science node connected to real data - Replicating ancient art traditions and master painting techniques with real physics and canon",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bekalah/cathedral.git",
    "directory": "packages/art-generation-node"
  },
  "scripts": {
