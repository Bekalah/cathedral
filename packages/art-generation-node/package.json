    "dev": "tsc --watch",
    "generate": "node dist/generators/patternGenerator.js",
    "analyze": "node dist/analyzers/patternAnalyzer.js",
    "fusion": "node dist/fusion/fusionEngine.js"
  },
  "dependencies": {
    "@cathedral/shared": "workspace:*",
    "canvas": "^2.11.2",
    "d3": "^7.8.5",
    "ml-matrix": "^6.10.4",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/d3": "^7.4.0",
    "@types/lodash": "^4.14.202",
    "typescript": "^5.3.0"
  },
