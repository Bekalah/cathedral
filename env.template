# 🏰 Cathedral Environment Variables Template
# 
# SECURITY: Copy this file to .env and fill in your values
# NEVER commit .env files to version control!
#
# Usage:
#   cp env.template .env
#   # Edit .env with your secure values

# ===========================================
# Application Settings
# ===========================================
NODE_ENV=development
CATHEDRAL_ENV=development
APP_PORT=3000

# ===========================================
# PostgreSQL Database (REQUIRED for Docker)
# ===========================================
# Generate a secure password: openssl rand -base64 32
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cathedral
POSTGRES_USER=cathedral
POSTGRES_PASSWORD=CHANGE_ME_USE_SECURE_PASSWORD

# Full connection string (auto-constructed in Docker)
# DATABASE_URL=postgresql://cathedral:PASSWORD@localhost:5432/cathedral

# ===========================================
# Redis Cache (OPTIONAL)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# SQLite (Local Development)
# ===========================================
SQLITE_DATABASE_PATH=./data/cathedral.db

# ===========================================
# PgAdmin (Development Only)
# ===========================================
PGADMIN_EMAIL=admin@cathedral.local
PGADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
PGADMIN_PORT=5050

# ===========================================
# Monitoring (Optional)
# ===========================================
PROMETHEUS_PORT=9090

# ===========================================
# API Keys (Keep Secret!)
# ===========================================
# Never commit real API keys!
# GITHUB_TOKEN=
# VERCEL_TOKEN=
# CLOUDFLARE_API_TOKEN=

# ===========================================
# Security Settings
# ===========================================
# Session secret - generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# JWT secret - generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# Encryption key - generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# CORS Settings
# ===========================================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===========================================
# Cathedral Specific
# ===========================================
CODEX_VERSION=144:99
ARCANA_COUNT=22
FUSION_ENABLED=true
