{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "cathedral",
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": "apps/web/out",
  "framework": "nextjs",
  "regions": ["iad1"],
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/apps/web/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/apps/web/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Cathedral-Version",
          "value": "2.0.0"
        },
        {
          "key": "X-Codex-Version",
          "value": "144:99"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/synth-lab",
      "destination": "/apps/synth-lab/index.html"
    },
    {
      "source": "/tarot-arena",
      "destination": "/apps/tarot-arena/index.html"
    }
  ],
  "trailingSlash": true,
  "cleanUrls": true,
  "functions": {
    "apps/web/api/**/*.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    }
  }
}

